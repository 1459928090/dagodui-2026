{
  "envId": "dagodui-d9gnhl56p7e817b74",
  "version": "2.0",
  "functionRoot": "./cloudfunctions",
  "functions": [],
  "hosting": {
    "headers": [
      {
        "source": "/js/*.js",
        "headers": [
          { "key": "Cache-Control", "value": "max-age=60" }
        ]
      },
      {
        "source": "/*.html",
        "headers": [
          { "key": "Cache-Control", "value": "max-age=60" }
        ]
      }
    ]
  }
}
